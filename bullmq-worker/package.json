{
  "name": "mediacreator-bullmq-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Background job worker for MediaCreator. Pulls from Upstash Redis BullMQ queues and invokes Base44 backend functions at a controlled rate.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@sentry/node": "^8.40.0",
    "bullmq": "^5.34.0",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}